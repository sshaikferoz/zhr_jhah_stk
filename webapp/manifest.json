{
  "_version": "1.60.0",
  "sap.app": {
    "id": "com.jhah.zhrjhahsecstk",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.28.0",
      "toolsId": "14285fc2-5ef0-4bf9-b064-fb15a12fca1a"
    },
    "dataSources": {
      "annotation": {
        "type": "ODataAnnotation",
        "uri": "annotations/annotation.xml",
        "settings": {
          "localUri": "annotations/annotation.xml"
        }
      },
      "mainService": {
        "uri": "/sap/opu/odata4/sap/zui_hr_stk/srvd/sap/zsrv_hr_stk/0001/",
        "type": "OData",
        "settings": {
          "annotations": [
            "annotation"
          ],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "4.0"
        }
      },
      "varService": {
        "uri": "/sap/opu/odata4/sap/zhr_var_app_srv_bind/srvd/sap/zhr_var_app_srv_defn/0001/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.120.39",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.jhah.zhrjhahsecstk.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "varAuth": {
        "dataSource": "varService",
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "StickerMasterList",
          "target": "StickerMasterList"
        },
        {
          "pattern": "StickerMaster({key}):?query:",
          "name": "StickerMasterObjectPage",
          "target": "StickerMasterObjectPage"
        }
      ],
      "targets": {
        "StickerMasterList": {
          "type": "Component",
          "id": "StickerMasterList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/StickerMaster",
              "variantManagement": "Page",
              "navigation": {
                "StickerMaster": {
                  "detail": {
                    "route": "StickerMasterObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              },
              "initialLoad": "Enabled"
            }
          }
        },
        "StickerMasterObjectPage": {
          "type": "Component",
          "id": "StickerMasterObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/StickerMaster",
              "content": {
                "header": {
                  "facets": {
                    "customViolatorStrip": {
                      "type": "XMLFragment",
                      "name": "com.jhah.zhrjhahsecstk.ext.fragment.ViolatorStrip"
                    }
                  }
                },
                "body": {
                  "sections": {
                    "appointmentSlotSection": {
                      "template": "com.jhah.zhrjhahsecstk.ext.fragment.AppointmentSlots",
                      "title": "Appointment Slot",
                      "position": {
                        "placement": "Before",
                        "anchor": "AppointDetails"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "extends": {
      "extensions": {
        "sap.ui.controllerExtensions": {
          "sap.fe.templates.ListReport.ListReportController#com.jhah.zhrjhahsecstk::StickerMasterList": {
            "controllerName": "com.jhah.zhrjhahsecstk.ext.controller.StickerControllerExtension"
          },
          "sap.fe.templates.ObjectPage.ObjectPageController#com.jhah.zhrjhahsecstk::StickerMasterObjectPage": {
            "controllerName": "com.jhah.zhrjhahsecstk.ext.controller.StickerControllerExtension"
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
