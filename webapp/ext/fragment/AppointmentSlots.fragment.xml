<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    core:require="{ handler: 'com/jhah/zhrjhahsecstk/ext/controller/AppointmentSlots' }">

    <!--
        Custom "Appointment Slot" section.
        - Appointment Date: a DatePicker restricted to the dates that exist in the
          AppointmentSlot list (minDate/maxDate from the slot data, plus validation).
        - Time Slot: a dropdown of every slot (From - To) for the chosen date.
        Both write back to the Sticker Master entity (AppointmentDate,
        AppointmentFromTime, AppointmentToTime, SlotId). The slot data lives in the
        "apptslots" JSON model, populated by StickerControllerExtension.
    -->
    <form:SimpleForm
        layout="ResponsiveGridLayout"
        editable="true"
        labelSpanXL="4"
        labelSpanL="4"
        labelSpanM="4"
        labelSpanS="12"
        columnsXL="2"
        columnsL="2"
        columnsM="1">

        <form:content>
            <Label text="Appointment Date" labelFor="appointmentDatePicker" />
            <DatePicker
                id="appointmentDatePicker"
                value="{ path: 'AppointmentDate', type: 'sap.ui.model.odata.type.Date', formatOptions: { style: 'medium' } }"
                minDate="{apptslots>/minDate}"
                maxDate="{apptslots>/maxDate}"
                editable="{= ${ui>/isEditable} }"
                placeholder="Choose an available date"
                change="handler.onAppointmentDateChange" />

            <Label text="Time Slot" labelFor="appointmentSlotSelect" />
            <ComboBox
                id="appointmentSlotSelect"
                selectedKey="{SlotId}"
                editable="{= ${ui>/isEditable} }"
                placeholder="Select a time slot"
                items="{ path: 'apptslots>/currentSlots', templateShareable: false }"
                selectionChange="handler.onAppointmentSlotChange">
                <core:Item key="{apptslots>SlotId}" text="{apptslots>label}" />
            </ComboBox>
        </form:content>
    </form:SimpleForm>

</core:FragmentDefinition>
