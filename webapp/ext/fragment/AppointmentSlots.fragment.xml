<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    xmlns:macros="sap.fe.macros">

    <!--
        Unified "Appointment Information" section.
        - Appointment Date: DatePicker restricted to the dates in AppointmentSlot.
        - Time Slot: dropdown of every slot (12h AM/PM labels) for the chosen date.
        Picking writes back AppointmentDate, AppointmentFromTime, AppointmentToTime,
        SlotId (raw HH:MM:SS values); changing the date clears the slot.
        Event handlers live in StickerControllerExtension and are invoked through
        the Fiori elements .extension handler syntax. The slot data comes from the
        "apptslots" JSON model, also populated by StickerControllerExtension.
        The computed From/To time fields are intentionally not displayed.
    -->
    <form:SimpleForm
        layout="ResponsiveGridLayout"
        editable="true"
        title="Appointment Information"
        labelSpanXL="4"
        labelSpanL="4"
        labelSpanM="4"
        labelSpanS="12"
        columnsXL="2"
        columnsL="2"
        columnsM="1">

        <form:content>
            <Label text="Appointment Date" labelFor="appointmentDatePicker" />
            <DatePicker
                id="appointmentDatePicker"
                value="{ path: 'AppointmentDate', type: 'sap.ui.model.odata.type.Date', formatOptions: { style: 'medium' } }"
                minDate="{apptslots>/minDate}"
                maxDate="{apptslots>/maxDate}"
                editable="{= ${ui>/isEditable} }"
                placeholder="Choose an available date"
                change=".extension.com.jhah.zhrjhahsecstk.ext.controller.StickerControllerExtension.onAppointmentDateChange" />

            <Label text="Time Slot" labelFor="appointmentSlotSelect" />
            <ComboBox
                id="appointmentSlotSelect"
                selectedKey="{SlotId}"
                editable="{= ${ui>/isEditable} }"
                placeholder="Select a time slot"
                items="{ path: 'apptslots>/currentSlots', templateShareable: false }"
                selectionChange=".extension.com.jhah.zhrjhahsecstk.ext.controller.StickerControllerExtension.onAppointmentSlotChange">
                <core:Item key="{apptslots>SlotId}" text="{apptslots>label}" />
            </ComboBox>

            <Label text="Appointment Location" />
            <macros:Field metaPath="AppointmentLocation" />

            <Label text="Request Date" />
            <macros:Field metaPath="RequestDate" />
        </form:content>
    </form:SimpleForm>

</core:FragmentDefinition>
