<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:control="com.jhah.zhrjhahsecstk.ext.control">
    <!--
        Start-time picker, rendered as sibling form fields toggled by edit mode.
        Display mode shows the plain value; edit mode shows a grid of start-time
        chips for the chosen date (SlotGrid: a custom IFormContent wrapper,
        because ColumnLayout rejects VBox/HBox). The selected chip is Emphasized,
        full slots are disabled, and picking a chip carries its matching end time
        along (onAppointmentSlotPress).
        The key is synthetic (SlotId + "#" + FromTime) because the backend reuses a
        single SlotId for every interval of a day (e.g. "SLOT:20260718"), so SlotId
        alone cannot identify the picked slot.
    -->
    <Text
        id="appointmentSlotText"
        text="{ path: 'AppointmentFromTime', type: 'sap.ui.model.odata.type.TimeOfDay', formatOptions: { pattern: 'h:mm a' } }"
        visible="{= !${ui>/isEditable} }" />

    <Text
        id="appointmentSlotEmptyText"
        text="Select a date to view the available time slots."
        visible="{= ${ui>/isEditable} &amp;&amp; !${apptslots>/currentSlots}.length }" />

    <control:SlotGrid
        id="appointmentSlotGrid"
        visible="{= ${ui>/isEditable} }"
        content="{ path: 'apptslots>/currentSlots', templateShareable: false }">
        <Button
            id="appointmentSlotChip"
            text="{apptslots>fromLabel}"
            tooltip="{apptslots>label}"
            enabled="{= !${apptslots>full} }"
            type="{= ${apptslots>key} === ${apptslots>/selectedKey} ? 'Emphasized' : 'Default' }"
            press=".extension.com.jhah.zhrjhahsecstk.ext.controller.StickerControllerExtension.onAppointmentSlotPress" />
    </control:SlotGrid>
</core:FragmentDefinition>
