<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m">
    <!--
        Start-time picker, rendered as sibling form fields toggled by edit mode.
        Display mode shows the plain value; edit mode shows a value-help-only
        input (typing disabled). Clicking it opens the TimeSlotPopover fragment,
        a fixed-height popover with a grid of start-time chips for the chosen
        date (onAppointmentSlotValueHelp / onAppointmentSlotPress).
    -->
    <Text
        id="appointmentSlotText"
        text="{ path: 'AppointmentFromTime', type: 'sap.ui.model.odata.type.TimeOfDay', formatOptions: { pattern: 'h:mm a' } }"
        visible="{= !${ui>/isEditable} }" />

    <Input
        id="appointmentSlotInput"
        visible="{= ${ui>/isEditable} }"
        value="{apptslots>/selectedLabel}"
        placeholder="Start time"
        showValueHelp="true"
        valueHelpOnly="true"
        valueHelpRequest=".extension.com.jhah.zhrjhahsecstk.ext.controller.StickerControllerExtension.onAppointmentSlotValueHelp" />
</core:FragmentDefinition>
